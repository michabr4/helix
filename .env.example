# Service Delivery Manager — environment template
# App
NODE_ENV=development
PORT=3000
FRONTEND_PORT=3001

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=helix_sdm
DB_USER=serviceflow_admin
DB_PASSWORD=change_me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Security — REQUIRED: replace both secrets with unique random strings (openssl rand -hex 32)
# The server will refuse to start if either secret is left as the placeholder.
JWT_SECRET=replace_with_32_plus_chars
JWT_REFRESH_SECRET=replace_with_32_plus_chars_2
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
BCRYPT_ROUNDS=12

# OIDC SSO (optional) — set SSO_ENABLED=true and register redirect URI on the IdP
APP_PUBLIC_URL=http://localhost:3000
SSO_ENABLED=false
# Issuer URL used for OIDC discovery (no trailing slash). Examples:
#   Azure AD: https://login.microsoftonline.com/{tenant}/v2.0
#   Okta:     https://{org}.okta.com/oauth2/default
#   Cisco:    use the issuer from your Cisco Secure Access / org IdP admin console (often custom per tenant).
SSO_ISSUER=
SSO_CLIENT_ID=
# Confidential client: set secret. Public client (PKCE only): leave empty.
SSO_CLIENT_SECRET=
# Must exactly match the redirect URI registered at the IdP (typically this value):
SSO_REDIRECT_URI=http://localhost:3000/api/v1/auth/sso/callback
# After login, browser lands here; #accessToken=...&refreshToken=... is appended by the app.
SSO_SUCCESS_REDIRECT=http://localhost:3000/
SSO_SCOPES=openid profile email
# Auto-create mgm.users on first SSO (role must be admin|sdm|tam|csm|engineer|manager|viewer). Empty = disabled.
# SSO_JIT_DEFAULT_ROLE=viewer

# CORS / sockets (comma-separated; include :3000 if a static page on another port calls the API)
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
SOCKET_IO_PATH=/socket.io
SOCKET_IO_CORS=http://localhost:3001

# TAC
TAC_API_KEY=replace_me
TAC_API_SECRET=replace_me
TAC_BASE_URL=https://tools.cisco.com/tac/api/v2
TAC_CONTRACT_NUMBER=GES-W-2024-MGM

# DNA Center
DNA_CENTER_HOST=replace_me
DNA_CENTER_USERNAME=replace_me
DNA_CENTER_PASSWORD=replace_me
DNA_CENTER_PORT=443

# Smart Licensing
SMART_LICENSING_CLIENT_ID=replace_me
SMART_LICENSING_CLIENT_SECRET=replace_me
SMART_LICENSING_TOKEN_URL=https://cloudsso.cisco.com/as/token.oauth2
SMART_LICENSING_API_URL=https://swapi.cisco.com/services/api/smart-accounts-and-licensing

# WebEx — bot token used by POST /api/v1/integrations/webex/war-room (Helix mockup “Open war room”). Create a bot at developer.webex.com; token must allow creating spaces (rooms).
WEBEX_CLIENT_ID=replace_me
WEBEX_CLIENT_SECRET=replace_me
WEBEX_BOT_TOKEN=replace_me
WEBEX_WEBHOOK_SECRET=replace_me
WEBEX_REDIRECT_URI=http://localhost:3000/api/v1/integrations/webex/callback

# Support APIs (implied integrations)
CISCO_SUPPORT_API_KEY=replace_me
CISCO_SUPPORT_API_SECRET=replace_me

# PSIRT / OpenVuln (Wave 14 — sourceAdmin: psirt-openvuln)
OPENVULN_CLIENT_ID=replace_me
OPENVULN_CLIENT_SECRET=replace_me
OPENVULN_TOKEN_URL=https://id.cisco.com/oauth2/default/v1/token

# Cisco Field Notices (Wave 15 — sourceAdmin: field-notices)
FIELD_NOTICE_API_BASE_URL=
CISCO_FN_API_KEY=replace_me

# Firepower Management Center / FMC REST (Wave 16 — sourceAdmin: fmc)
FMC_BASE_URL=https://fmc.example.local
FMC_API_TOKEN=replace_me

# Power BI — Global PM dashboard embed (optional; service principal → GenerateToken)
POWERBI_ENABLED=false
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_WORKSPACE_ID=
POWERBI_REPORT_ID=

# Salesforce integration (Connected App — OAuth 2.0 password flow)
# Create a Connected App in Salesforce Setup → App Manager → New Connected App.
# Enable "Enable OAuth Settings", add "Full access (full)" or granular scopes.
# Use the Consumer Key/Secret below. The security token is appended to the password.
SALESFORCE_ENABLED=false
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_CLIENT_ID=replace_me
SALESFORCE_CLIENT_SECRET=replace_me
SALESFORCE_USERNAME=replace_me
SALESFORCE_PASSWORD=replace_me
SALESFORCE_SECURITY_TOKEN=replace_me
SALESFORCE_API_VERSION=v59.0
# OAuth flow: "client_credentials" (recommended — requires Connected App setup) or "password" (legacy ROPC)
SALESFORCE_OAUTH_FLOW=password

# Feature flags
ENABLE_TAC_AUTO_CREATE=true
ENABLE_TEAMS_INTEGRATION=true
ENABLE_WEBEX_INTEGRATION=true
ENABLE_EMAIL_NOTIFICATIONS=true
